<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/app_background"
    tools:context=".ubicacion.UbicacionInsertarActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_asignacion_ubicaciones"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/auto_import_text_dark"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_seleccione_bodega"
        android:textColor="@color/auto_import_text_dark"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spinnerUbicacionBodegas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_seleccione_seccion"
        android:textColor="@color/auto_import_text_dark"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spinnerUbicacionSecciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_seleccione_vehiculo"
        android:textColor="@color/auto_import_text_dark"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spinnerUbicacionVehiculos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/editFechaAsignacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/label_fecha_asignacion"
        android:focusable="false"
        android:clickable="true"
        android:textColor="@color/auto_import_text_dark"
        android:textColorHint="@color/auto_import_hint"
        android:layout_marginBottom="24dp"
        android:autofillHints="none"
        android:inputType="date"/>

    <Button
        android:id="@+id/btnGuardarUbicacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_save"
        android:backgroundTint="@color/auto_import_dark"
        android:textColor="@color/white"/>

    <Button
        android:id="@+id/btnLimpiarUbicacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_clean"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:textColor="@color/auto_import_dark"
        android:layout_marginTop="8dp"/>

</LinearLayout>
