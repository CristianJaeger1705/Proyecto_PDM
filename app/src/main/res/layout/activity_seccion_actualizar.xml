<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:id="@+id/main"
    android:background="@color/app_background"
    tools:context=".seccion.SeccionActualizarActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_actualizar_seccion"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/auto_import_text_dark"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_seleccione_bodega"
        android:textColor="@color/auto_import_text_dark"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spinnerActualizarBodegas"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/white"
        android:padding="8dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Seleccione Sección a Modificar:"
        android:textColor="@color/auto_import_text_dark"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spinnerActualizarSecciones"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/white"
        android:padding="8dp"
        android:layout_marginBottom="24dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/auto_import_border_grey"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/editActualizarNivel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/label_nivel"
        android:inputType="number"
        android:textColor="@color/auto_import_text_dark"
        android:textColorHint="@color/auto_import_hint"
        android:layout_marginBottom="12dp"
        android:autofillHints="none"/>

    <EditText
        android:id="@+id/editActualizarCapacidadSeccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/label_capacidad_vehiculos"
        android:inputType="number"
        android:textColor="@color/auto_import_text_dark"
        android:textColorHint="@color/auto_import_hint"
        android:layout_marginBottom="24dp"
        android:autofillHints="none"/>

    <Button
        android:id="@+id/btnActualizarSeccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_save"
        android:backgroundTint="@color/auto_import_dark"
        android:textColor="@color/white"/>

</LinearLayout>
