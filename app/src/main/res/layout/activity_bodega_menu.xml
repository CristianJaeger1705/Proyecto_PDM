<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="@color/app_background"
    tools:context=".bodega.BodegaMenuActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_gestion_bodegas"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/auto_import_text_dark"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnMenuInsertar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_insertar_bodega"
        android:backgroundTint="@color/auto_import_dark"
        android:textColor="@color/white"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnMenuConsultar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_consultar_bodega"
        android:backgroundTint="@color/auto_import_dark"
        android:textColor="@color/white"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnMenuActualizar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_actualizar_bodega"
        android:backgroundTint="@color/auto_import_dark"
        android:textColor="@color/white"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnMenuEliminar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_eliminar_bodega"
        android:backgroundTint="@color/auto_import_red"
        android:textColor="@color/white"
        android:layout_marginBottom="40dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/auto_import_border_grey"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnGestionSecciones"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/title_gestion_secciones"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:textColor="@color/auto_import_dark"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnGestionUbicaciones"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/title_asignacion_ubicaciones"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:textColor="@color/auto_import_dark"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnBodegasWeb"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="BODEGAS EN LA NUBE"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:textColor="@color/auto_import_dark"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnDisponibilidadWeb"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="VER DISPONIBILIDAD (WEB)"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:textColor="@color/auto_import_dark"/>

</LinearLayout>
