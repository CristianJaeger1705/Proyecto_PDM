<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".importador.ImportadorInsertarActivity">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Insertar Importador"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NUI (Número Único de Importador)*"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorNUI"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: IMP0000001"
            android:inputType="text"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre*"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apellido*"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorApellido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Apellido"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apellido de Casada (opcional)"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorApellidoCasada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Solo si aplica"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Género*"
            android:textStyle="bold"/>
        <Spinner
            android:id="@+id/spinnerImportadorGenero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha de Nacimiento*"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Toque para seleccionar fecha"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dirección*"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorDireccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Dirección completa"
            android:inputType="textMultiLine"
            android:lines="2"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correo Electrónico*"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorCorreo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="correo@ejemplo.com"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NUI Responsable (opcional)"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editImportadorNUIResponsable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="NUI del responsable"
            android:inputType="text"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnGuardarImportador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GUARDAR IMPORTADOR"/>

        <Button
            android:id="@+id/btnLimpiarImportador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LIMPIAR CAMPOS"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>