<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="@color/white"
    tools:context=".importacion.ImportacionEliminarActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_delete_importacion"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_importacion_to_delete"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinnerEliminarIdImportacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEliminarImportacion"
        style="@style/AutoImportButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_delete"
        android:backgroundTint="#FF5252"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLimpiarEliminar"
        style="@style/AutoImportButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_clean"
        android:backgroundTint="#888888"/>

</LinearLayout>