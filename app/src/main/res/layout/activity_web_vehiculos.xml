<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Vehículos Web"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:textColor="@color/auto_import_text_dark"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Filtrar por estado:"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:textColor="@color/auto_import_text_dark"/>

    <Spinner
        android:id="@+id/spinnerFiltroEstado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCargarVehiculos"
        style="@style/AutoImportButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cargar Vehículos"
        android:backgroundTint="@color/auto_import_dark"
        android:layout_marginBottom="16dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/auto_import_grey"
        android:padding="8dp">

        <TextView
            android:id="@+id/txtResultadosVehiculos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/auto_import_text_dark"
            android:hint="Los resultados aparecerán aquí"
            android:lineSpacingExtra="4dp"/>

    </ScrollView>

</LinearLayout>
