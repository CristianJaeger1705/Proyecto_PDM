<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:id="@+id/main"
    android:background="@color/app_background"
    tools:context=".bodega.BodegaActualizarActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_actualizar_bodega"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/auto_import_text_dark"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/editActualizarIdBodega"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/label_id_bodega"
            android:inputType="number"
            android:textColor="@color/auto_import_text_dark"
            android:textColorHint="@color/auto_import_hint"
            android:autofillHints="none"/>

        <Button
            android:id="@+id/btnCargarBodega"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_load"
            android:backgroundTint="@color/auto_import_dark"
            android:textColor="@color/white"/>
    </LinearLayout>

    <EditText
        android:id="@+id/editActualizarNombreBodega"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/label_nombre_bodega"
        android:inputType="text"
        android:textColor="@color/auto_import_text_dark"
        android:textColorHint="@color/auto_import_hint"
        android:layout_marginBottom="12dp"
        android:autofillHints="name"/>

    <EditText
        android:id="@+id/editActualizarDepartamento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/label_departamento"
        android:inputType="text"
        android:textColor="@color/auto_import_text_dark"
        android:textColorHint="@color/auto_import_hint"
        android:layout_marginBottom="12dp"
        android:autofillHints="postalAddress"/>

    <EditText
        android:id="@+id/editActualizarDireccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/label_direccion"
        android:inputType="text"
        android:textColor="@color/auto_import_text_dark"
        android:textColorHint="@color/auto_import_hint"
        android:layout_marginBottom="12dp"
        android:autofillHints="streetAddress"/>

    <EditText
        android:id="@+id/editActualizarCapacidad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/label_capacidad_secciones"
        android:inputType="number"
        android:textColor="@color/auto_import_text_dark"
        android:textColorHint="@color/auto_import_hint"
        android:layout_marginBottom="24dp"
        android:autofillHints="none"/>

    <Button
        android:id="@+id/btnActualizarBodega"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_save"
        android:backgroundTint="@color/auto_import_dark"
        android:textColor="@color/white"/>

</LinearLayout>
