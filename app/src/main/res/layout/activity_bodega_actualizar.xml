<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white"
    tools:context=".bodega.BodegaActualizarActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_actualizar_bodega"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/auto_import_dark"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_id_bodega"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <Spinner
            android:id="@+id/spinnerActualizarBodegaId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="48dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCargarBodega"
            style="@style/AutoImportButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_load"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_nombre_bodega"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/editActualizarNombreBodega"
        style="@style/AutoImportEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/label_nombre_bodega"
        android:inputType="text"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_departamento"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/editActualizarDepartamento"
        style="@style/AutoImportEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/label_departamento"
        android:inputType="text"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_direccion"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/editActualizarDireccion"
        style="@style/AutoImportEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/label_direccion"
        android:inputType="text"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_capacidad_secciones"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/editActualizarCapacidad"
        style="@style/AutoImportEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/label_capacidad_secciones"
        android:inputType="number"
        android:enabled="false"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnActualizarBodega"
        style="@style/AutoImportButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_save_changes"
        android:layout_marginTop="16dp"/>

</LinearLayout>
