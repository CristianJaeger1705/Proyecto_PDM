<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".estadovehicular.EstadoVehicularGestionActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_estado_vehicular"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_vin"
            android:textStyle="bold"/>
        <Spinner
            android:id="@+id/spinnerVehiculoEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_historial_estados"
            android:textStyle="bold"/>
        <Spinner
            android:id="@+id/spinnerHistorialEstados"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_desc_estado"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editDescripcionEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_desc_estado"
            android:inputType="textMultiLine"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_fecha_registro"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/editFechaEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_fecha_nacimiento"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_fotografia"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <ImageView
            android:id="@+id/imgVehiculoEstado"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#EEEEEE"
            android:scaleType="centerInside"
            android:layout_marginBottom="8dp"
            android:contentDescription="@string/label_fotografia"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSeleccionarImagen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_change_image"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginBottom="24dp"
            android:textColor="@color/auto_import_dark"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnInsertarEstado"
                style="@style/AutoImportButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_insert_new"
                android:layout_margin="4dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConsultarEstado"
                style="@style/AutoImportButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_reload"
                android:layout_margin="4dp"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnActualizarEstado"
                style="@style/AutoImportButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_update"
                android:layout_margin="4dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEliminarEstado"
                style="@style/AutoImportButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:text="@string/btn_delete"
                android:backgroundTint="#FF5252"
                android:layout_margin="4dp"/>
        </GridLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLimpiarEstado"
            style="@style/AutoImportButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_clean"
            android:backgroundTint="#888888"
            android:layout_marginTop="12dp"/>

    </LinearLayout>
</ScrollView>