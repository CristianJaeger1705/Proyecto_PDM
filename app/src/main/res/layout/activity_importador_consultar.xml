<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".importador.ImportadorConsultarActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Consultar Importador"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/editConsultarNUI"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ingrese NUI a buscar"
        android:inputType="text"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnConsultarImportador"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BUSCAR"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/textResultadoImportador"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Resultado..."
        android:textSize="16sp"
        android:padding="12dp"
        android:background="#F0F0F0"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnLimpiarConsultarImportador"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LIMPIAR"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

</LinearLayout>